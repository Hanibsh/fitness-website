# Supabase configuration.
# Copy this file to `.env.local` (git-ignored) and fill in the values for local
# dev. For production, add the same two variables in the Vercel project's
# Settings → Environment Variables.
#
# Both values come from your Supabase project: Settings → API.
# The anon key is PUBLIC and safe to expose. NEVER put the `service_role` key here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
